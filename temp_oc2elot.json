\u05dc\u05d3\u05d0\u05d8\u05d4 \u05d7\u05dd \u05d5\u05d4\u05d9\u05e1\u05d8\u05d5\u05e8\u05d9. \u05d7\u05d9\u05e9\u05d5\u05d1 \u05de\u05d5\u05d0\u05e5 \u05e2\u05dd GPUs \u05d5-DPUs NVIDIA \u05de\u05e1\u05e4\u05e7\u05ea \u05e9\u05db\u05d1\u05ea \u05d7\u05d9\u05e9\u05d5\u05d1 \u05de\u05d5\u05d0\u05e5 \u05e2\u05dd GPUs \u05d5-DPUs \u05dc\u05e4\u05dc\u05d8\u05e4\u05d5\u05e8\u05de\u05ea Morpheus \u05dc\u05d6\u05d9\u05d4\u05d5\u05d9 \u05d0\u05e0\u05d5\u05de\u05dc\u05d9\u05d5\u05ea \u05d5\u05d0\u05d9\u05e0\u05e4\u05e8\u05e0\u05e1 \u05de\u05d4\u05d9\u05e8. \u05ea\u05d2\u05d5\u05d1\u05d4 \u05d0\u05d5\u05d8\u05d5\u05e0\u05d5\u05de\u05d9\u05ea \u05de\u05d1\u05d5\u05e1\u05e1\u05ea AI Leidos \u05de\u05e9\u05dc\u05d9\u05de\u05d4 \u05e2\u05dd \u05e1\u05d5\u05db\u05e0\u05d9 AI \u05d0\u05d5\u05d8\u05d5\u05e0\u05d5\u05de\u05d9\u05d9\u05dd \u05e9\u05de\u05d1\u05e6\u05e2\u05d9\u05dd \u05ea\u05d2\u05d5\u05d1\u05d4 \u05d1\u05d6\u05de\u05df \u05d0\u05de\u05ea \u05de\u05d1\u05d5\u05e1\u05e1\u05ea \u05de\u05d3\u05d9\u05e0\u05d9\u05d5\u05ea \u05d1\u05e1\u05d1\u05d9\u05d1\u05d5\u05ea \u05e7\u05e8\u05d9\u05d8\u05d9\u05d5\u05ea. \u05de\u05e2\u05e8\u05db\u05ea \u05d0\u05d9\u05e0\u05d8\u05d2\u05e8\u05d8\u05d9\u05d1\u05d9\u05ea \u05de\u05ea\u05e7\u05d3\u05de\u05ea \u05d4\u05e9\u05d9\u05dc\u05d5\u05d1 \u05d1\u05d9\u05df VAST, NVIDIA \u05d5-Leidos \u05d9\u05d5\u05e6\u05e8 \u05de\u05e2\u05e8\u05db\u05ea \u05dc\u05e0\u05d9\u05ea\u05d5\u05d7, \u05e7\u05d1\u05dc\u05ea \u05d4\u05d7\u05dc\u05d8\u05d5\u05ea \u05d5\u05ea\u05d2\u05d5\u05d1\u05d4 \u05de\u05d4\u05d9\u05e8\u05d4 \u05d1\u05e1\u05d1\u05d9\u05d1\u05d5\u05ea \u05e7\u05e8\u05d9\u05d8\u05d9\u05d5\u05ea. [SLIDE 4]: \u05de\u05d9\u05e0\u05d5\u05e3 \u05d4\u05e4\u05ea\u05e8\u05d5\u05df \u05d1\u05e9\u05d5\u05d5\u05e7\u05d9\u05dd \u05e6\u05d9\u05d1\u05d5\u05e8\u05d9\u05d9\u05dd, \u05e6\u05d1\u05d0\u05d9\u05d9\u05dd \u05d5\u05e4\u05e8\u05d8\u05d9\u05d9\u05dd \u05d9\u05d9\u05e9\u05d5\u05dd \u05d1\u05e9\u05d5\u05e7 \u05d4\u05e6\u05d9\u05d1\u05d5\u05e8\u05d9 \u05d4\u05e4\u05ea\u05e8\u05d5\u05df \u05de\u05ea\u05d0\u05d9\u05dd \u05dc\u05e0\u05d9\u05d4\u05d5\u05dc \u05ea\u05e9\u05ea\u05d9\u05d5\u05ea \u05e7\u05e8\u05d9\u05d8\u05d9\u05d5\u05ea \u05db\u05de\u05d5 \u05d7\u05e9\u05de\u05dc, \u05de\u05d9\u05dd \u05d5\u05ea\u05d7\u05d1\u05d5\u05e8\u05d4 \u05e2\u05dd \u05ea\u05d2\u05d5\u05d1\u05d4 \u05d0\u05d5\u05d8\u05d5\u05de\u05d8\u05d9\u05ea \u05d1\u05d6\u05de\u05df \u05d0\u05de\u05ea. \u05e9\u05d9\u05dc\u05d5\u05d1 \u05d1\u05e9\u05d5\u05e7 \u05d4\u05e6\u05d1\u05d0\u05d9 \u05d4\u05e4\u05ea\u05e8\u05d5\u05df \u05de\u05e9\u05ea\u05dc\u05d1 \u05d1\u05de\u05e2\u05e8\u05db\u05d5\u05ea \u05e4\u05d9\u05e7\u05d5\u05d3 \u05d5\u05e9\u05dc\u05d9\u05d8\u05d4, \u05e0\u05d9\u05ea\u05d5\u05d7 \u05de\u05d5\u05d3\u05d9\u05e2\u05d9\u05df \u05d5\u05ea\u05d2\u05d5\u05d1\u05d4 \u05dc\u05d0\u05d9\u05d5\u05de\u05d9\u05dd \u05de\u05d1\u05e6\u05e2\u05d9\u05d9\u05dd \u05d1\u05d9\u05e2\u05d9\u05dc\u05d5\u05ea \u05d2\u05d1\u05d5\u05d4\u05d4. \u05d9\u05d9\u05e9\u05d5\u05de\u05d9\u05dd \u05d1\u05e9\u05d5\u05e7 \u05d4\u05e4\u05e8\u05d8\u05d9 \u05d4\u05e4\u05ea\u05e8\u05d5\u05df \u05de\u05e9\u05e4\u05e8 \u05e0\u05d9\u05d4\u05d5\u05dc \u05e6\u05d9 \u05dc\u05d5\u05d5\u05d9\u05d9\u05e0\u05d9\u05dd, \u05d7\u05e7\u05dc\u05d0\u05d5\u05ea \u05de\u05d3\u05d5\u05d9\u05e7\u05ea \u05d5\u05d0\u05d5\u05e4\u05d8\u05d9\u05de\u05d9\u05d6\u05e6\u05d9\u05d4 \u05dc\u05d5\u05d2\u05d9\u05e1\u05d8\u05d9\u05ea \u05dc\u05d7\u05d9\u05e1\u05db\u05d5\u05df \u05d1\u05de\u05e9\u05d0\u05d1\u05d9\u05dd. \u05e2\u05e8\u05da \u05de\u05d5\u05e1\u05e3 \u05d5\u05d1\u05d9\u05e6\u05d5\u05e2\u05d9\u05dd \u05d4\u05e4\u05ea\u05e8\u05d5\u05df \u05de\u05d0\u05e4\u05e9\u05e8 \u05e0\u05d9\u05ea\u05d5\u05d7\u05d9\u05dd \u05d1\u05d6\u05de\u05df \u05d0\u05de\u05ea, \u05ea\u05d2\u05d5\u05d1\u05d4 \u05d0\u05d5\u05d8\u05d5\u05e0\u05d5\u05de\u05d9\u05ea \u05d5\u05e9\u05d9\u05e4\u05d5\u05e8 \u05d1\u05d9\u05e6\u05d5\u05e2\u05d9\u05dd \u05ea\u05e4\u05e2\u05d5\u05dc\u05d9\u05d9\u05dd \u05de\u05e9\u05de\u05e2\u05d5\u05ea\u05d9. [SLIDE 5]: \u05d4\u05e4\u05dc\u05d8\u05e4\u05d5\u05e8\u05de\u05d4 OC2ELOT [SLIDE 6]: \u05d4\u05d2\u05d3\u05e8\u05d4 \u05d5\u05d9\u05ea\u05e8\u05d5\u05e0\u05d5\u05ea \u05de\u05d5\u05dc \u05de\u05e2\u05e8\u05db\u05d5\u05ea C2 \u05e8\u05d2\u05d9\u05dc\u05d5\u05ea \u05e4\u05dc\u05d8\u05e4\u05d5\u05e8\u05de\u05d4 \u05de\u05ea\u05e7\u05d3\u05de\u05ea \u05dc\u05e0\u05d9\u05d4\u05d5\u05dc \u05e4\u05d9\u05e7\u05d5\u05d3 OC2ELOT \u05d4\u05d9\u05d0 \u05de\u05e2\u05e8\u05db\u05ea \u05d0\u05d9\u05e0\u05d8\u05d2\u05e8\u05e6\u05d9\u05d4 \u05d3\u05d9\u05d2\u05d9\u05d8\u05dc\u05d9\u05ea \u05e8\u05d1-\u05ea\u05d7\u05d5\u05de\u05d9\u05ea \u05dc\u05e0\u05d9\u05d4\u05d5\u05dc \u05e4\u05d9\u05e7\u05d5\u05d3 \u05d5\u05e9\u05dc\u05d9\u05d8\u05d4 \u05de\u05d1\u05d5\u05e1\u05e1\u05ea \u05d0\u05e8\u05db\u05d9\u05d8\u05e7\u05d8\u05d5\u05e8\u05d4 \u05e4\u05ea\u05d5\u05d7\u05d4 \u05d5-DevSecOps. \u05ea\u05d2\u05d5\u05d1\u05d4 \u05d4\u05d9\u05e4\u05e8-\u05e1\u05d5\u05e0\u05d9\u05ea \u05de\u05d4\u05d9\u05e8\u05d4 \u05d4\u05de\u05e2\u05e8\u05db\u05ea \u05de\u05d0\u05e4\u05e9\u05e8\u05ea \u05ea\u05d2\u05d5\u05d1\u05d4 \u05d4\u05d9\u05e4\u05e8-\u05e1\u05d5\u05e0\u05d9\u05ea \u05ea\u05d5\u05da 1.1 \u05e9\u05e0\u05d9\u05d5\u05ea, \u05dc\u05e9\u05d1\u05d9\u05e8\u05ea \u05e9\u05e8\u05e9\u05e8\u05ea \u05d4\u05d4\u05e8\u05d2 \u05d1\u05d6\u05de\u05df \u05d0\u05de\u05ea. \u05d0\u05d9\u05d7\u05d5\u05d3 \u05e0\u05ea\u05d5\u05e0\u05d9\u05dd \u05e8\u05d1-\u05ea\u05d7\u05d5\u05de\u05d9 OC2ELOT \u05de\u05d0\u05d7\u05d3\u05ea \u05de\u05d9\u05d3\u05e2 \u05de\u05d7\u05dc\u05dc, \u05e7\u05e8\u05e7\u05e2, \u05e1\u05d9\u05d9\u05d1\u05e8 \u05d5\u05de\u05d6\u05d2 \u05d0\u05d5\u05d5\u05d9\u05e8 \u05dc\u05ea\u05de\u05d5\u05e0\u05d4 \u05de\u05e7\u05d9\u05e4\u05d4 \u05d0\u05d7\u05ea \u05dc\u05e9\u05d9\u05e4\u05d5\u05e8 \u05e7\u05d1\u05dc\u05ea \u05d4\u05d4\u05d7\u05dc\u05d8\u05d5\u05ea. \u05d2\u05de\u05d9\u05e9\u05d5\u05ea \u05d5\u05e9\u05d3\u05e8\u05d5\u05d2\u05d9\u05dd \u05de\u05d4\u05d9\u05e8\u05d9\u05dd \u05d4\u05d0\u05e8\u05db\u05d9\u05d8\u05e7\u05d8\u05d5\u05e8\u05d4 \u05d4\u05e4\u05ea\u05d5\u05d7\u05d4 \u05de\u05d0\u05e4\u05e9\u05e8\u05ea \u05d7\u05d9\u05d1\u05d5\u05e8 \u05d7\u05d9\u05d9\u05e9\u05e0\u05d9\u05dd \u05de\u05e1\u05d7\u05e8\u05d9\u05d9\u05dd \u05d5\u05e9\u05d3\u05e8\u05d5\u05d2\u05d9\u05dd \u05de\u05d4\u05d9\u05e8\u05d9\u05dd \u05dc\u05dc\u05d0 \u05ea\u05dc\u05d5\u05ea \u05d1\u05de\u05e2\u05e8\u05db\u05d5\u05ea \u05e1\u05d2\u05d5\u05e8\u05d5\u05ea. [SLIDE 7]: \u05de\u05e8\u05db\u05d9\u05d1\u05d9 \u05d4\u05e4\u05ea\u05e8\u05d5\u05df \u05d4\u05d8\u05db\u05e0\u05d5\u05dc\u05d5\u05d2\u05d9\u05d9\u05dd \u05e7\u05d8\u05dc\u05d5\u05d2 \u05e9\u05d9\u05e8\u05d5\u05ea\u05d9\u05dd \u05e7\u05d5\u05de\u05e4\u05d5\u05d6\u05d1\u05d9\u05dc\u05d9 \u05d4\u05e4\u05ea\u05e8\u05d5\u05df \u05db\u05d5\u05dc\u05dc \u05e7\u05d8\u05dc\u05d5\u05d2 \u05e9\u05d9\u05e8\u05d5\u05ea\u05d9\u05dd \u05e9\u05de\u05d0\u05e4\u05e9\u05e8 \u05e4\u05d9\u05ea\u05d5\u05d7 \u05de\u05d4\u05d9\u05e8 \u05d5\u05d2\u05de\u05d9\u05e9 \u05e9\u05dc \u05d9\u05db\u05d5\u05dc\u05d5\u05ea \u05d8\u05db\u05e0\u05d5\u05dc\u05d5\u05d2\u05d9\u05d5\u05ea \u05de\u05ea\u05e7\u05d3\u05de\u05d5\u05ea. \u05ea\u05e9\u05ea\u05d9\u05ea \u05de\u05d5\u05dc\u05d8\u05d9-\u05e4\u05dc\u05d8\u05e4\u05d5\u05e8\u05dd \u05d4\u05ea\u05e9\u05ea\u05d9\u05ea \u05e4\u05d5\u05e2\u05dc\u05ea \u05d1\u05e2\u05e0\u05df, On-Prem \u05d5-Edge \u05d5\u05de\u05e1\u05e4\u05e7\u05ea \u05d2\u05de\u05d9\u05e9\u05d5\u05ea \u05ea\u05e4\u05e2\u05d5\u05dc\u05d9\u05ea \u05e8\u05d7\u05d1\u05d4. \u05d0\u05d9\u05e0\u05d8\u05d2\u05e8\u05e6\u05d9\u05d4 \u05e4\u05d5\u05e0\u05e7\u05e6\u05d9\u05d5\u05e0\u05dc\u05d9\u05ea \u05d0\u05d9\u05e0\u05d8\u05d2\u05e8\u05e6\u05d9\u05d4 \u05e2\u05dd \u05de\u05d5\u05d3\u05dc\u05d9\u05dd, \u05e1\u05d9\u05de\u05d5\u05dc\u05e6\u05d9\u05d5\u05ea \u05d5\u05d1\u05d9\u05e0\u05d4 \u05de\u05dc\u05d0\u05db\u05d5\u05ea\u05d9\u05ea \u05de\u05e9\u05e4\u05e8\u05ea \u05d9\u05db\u05d5\u05dc\u05d5\u05ea \u05d0\u05e0\u05dc\u05d9\u05d8\u05d9\u05d5\u05ea \u05d5\u05d7\u05d9\u05d6\u05d5\u05d9. \u05d0\u05d9\u05e0\u05d8\u05d2\u05e8\u05e6\u05d9\u05d9\u05ea \u05e0\u05ea\u05d5\u05e0\u05d9\u05dd \u05de\u05d5\u05d3\u05d5\u05dc\u05e8\u05d9\u05ea \u05e0\u05ea\u05d5\u05e0\u05d9\u05dd \u05de\u05e9\u05d5\u05d3\u05e8\u05d9\u05dd, \u05de\u05e0\u05d5\u05e8\u05de\u05dc\u05d9\u05dd \u05d5\u05de\u05ea\u05d5\u05d9\u05d9\u05d2\u05d9\u05dd \u05d1\u05e6\u05d5\u05e8\u05d4 \u05de\u05d5\u05d3\u05d5\u05dc\u05e8\u05d9\u05ea \u05dc\u05e9\u05d9\u05e4\u05d5\u05e8 \u05d4\u05d3\u05d9\u05d5\u05e7 \u05d5\u05d4\u05d0\u05de\u05d9\u05e0\u05d5\u05ea. [SLIDE 8]: \u05d9\u05d9\u05e9\u05d5\u05de\u05d9\u05dd \u05d0\u05d6\u05e8\u05d7\u05d9\u05d9\u05dd \u05d5\u05dc\u05e7\u05d5\u05d7\u05d5\u05ea \u05e4\u05d5\u05d8\u05e0\u05e6\u05d9\u05d0\u05dc\u05d9\u05d9\u05dd \u05ea\u05d7\u05d1\u05d5\u05e8\u05d4 \u05d5\u05dc\u05d5\u05d2\u05d9\u05e1\u05d8\u05d9\u05e7\u05d4 \u05d7\u05db\u05de\u05d4 \u05d4\u05e4\u05dc\u05d8\u05e4\u05d5\u05e8\u05de\u05d4 \u05ea\u05d5\u05de\u05db\u05ea \u05d1\u05e0\u05d9\u05d4\u05d5\u05dc \u05e0\u05de\u05dc\u05d9\u05dd \u05d5\u05e6\u05d9 \u05e8\u05db\u05d1\u05d9\u05dd \u05d0\u05d5\u05d8\u05d5\u05e0\u05d5\u05de\u05d9\u05d9\u05dd \u05dc\u05e9\u05d9\u05e4\u05d5\u05e8 \u05d9\u05e2\u05d9\u05dc\u05d5\u05ea \u05d5\u05d7\u05d9\u05e1\u05db\u05d5\u05df \u05d1\u05de\u05e9\u05d0\u05d1\u05d9\u05dd. \u05e0\u05d9\u05d4\u05d5\u05dc \u05ea\u05e9\u05ea\u05d9\u05d5\u05ea \u05e7\u05e8\u05d9\u05d8\u05d9\u05d5\u05ea \u05ea\u05de\u05d9\u05db\u05d4 \u05d1\u05e0\u05d9\u05d4\u05d5\u05dc \u05e8\u05e9\u05ea\u05d5\u05ea \u05d7\u05e9\u05de\u05dc, \u05de\u05d9\u05dd \u05d5\u05d2\u05d6 \u05dc\u05e9\u05de\u05d9\u05e8\u05ea \u05d9\u05e6\u05d9\u05d1\u05d5\u05ea \u05d5\u05d1\u05d8\u05d7\u05d5\u05df \u05ea\u05e4\u05e2\u05d5\u05dc\u05d9. \u05e9\u05d9\u05e8\u05d5\u05ea\u05d9 \u05d7\u05d9\u05e8\u05d5\u05dd \u05d5\u05e0\u05d9\u05d4\u05d5\u05dc \u05d0\u05e1\u05d5\u05e0\u05d5\u05ea \u05d4\u05e4\u05dc\u05d8\u05e4\u05d5\u05e8\u05de\u05d4 \u05de\u05d0\u05e4\u05e9\u05e8\u05ea \u05ea\u05d2\u05d5\u05d1\u05d4 \u05de\u05d4\u05d9\u05e8\u05d4 \u05d5\u05d9\u05e2\u05d9\u05dc\u05d4 \u05dc\u05e0\u05d9\u05d4\u05d5\u05dc \u05d0\u05e1\u05d5\u05e0\u05d5\u05ea \u05d8\u05d1\u05e2 \u05d5\u05e9\u05d9\u05e8\u05d5\u05ea\u05d9 \u05d7\u05d9\u05e8\u05d5\u05dd. \u05d7\u05e7\u05dc\u05d0\u05d5\u05ea \u05de\u05d3\u05d5\u05d9\u05e7\u05ea \u05d5\u05dc\u05d5\u05d5\u05d9\u05d9\u05e0\u05d9\u05dd \u05de\u05e1\u05d7\u05e8\u05d9\u05d9\u05dd \u05e0\u05d9\u05d8\u05d5\u05e8 \u05d5\u05d4\u05e9\u05e7\u05d9\u05d4 \u05de\u05de\u05d5\u05e7\u05d3\u05d9\u05dd \u05d1\u05d7\u05e7\u05dc\u05d0\u05d5\u05ea \u05d5\u05e0\u05d9\u05d4\u05d5\u05dc \u05ea\u05e0\u05d5\u05e2\u05ea \u05dc\u05d5\u05d5\u05d9\u05d9\u05e0\u05d9\u05dd \u05de\u05e1\u05d7\u05e8\u05d9\u05d9\u05dd \u05d1\u05d6\u05de\u05df \u05d0\u05de\u05ea. [SLIDE 9]: \u05d9\u05d9\u05e9\u05d5\u05dd \u05e2\u05e7\u05e8\u05d5\u05e0\u05d5\u05ea DevSecOps \u05d1\u05e4\u05dc\u05d8\u05e4\u05d5\u05e8\u05de\u05d4 \u05d0\u05d9\u05e0\u05d8\u05d2\u05e8\u05e6\u05d9\u05d4 \u05de\u05ea\u05de\u05e9\u05db\u05ea \u05d5\u05d0\u05e1\u05e4\u05e7\u05d4 \u05de\u05ea\u05de\u05e9\u05db\u05ea OC2ELOT \u05de\u05e9\u05ea\u05de\u05e9\u05ea \u05d1-CI/CD \u05e2\u05dd \u05e7\u05d8\u05dc\u05d5\u05d2 \u05e9\u05d9\u05e8\u05d5\u05ea\u05d9\u05dd \u05e7\u05d5\u05de\u05e4\u05d5\u05d6\u05d1\u05d9\u05dc\u05d9 \u05d4\u05de\u05d0\u05e4\u05e9\u05e8 \u05e4\u05d9\u05ea\u05d5\u05d7 \u05d5\u05e9\u05d3\u05e8\u05d5\u05d2 \u05de\u05d4\u05d9\u05e8\u05d9\u05dd \u05d5\u05d3\u05d9\u05e0\u05de\u05d9\u05d9\u05dd. \u05d0\u05d1\u05d8\u05d7\u05d4 \u05de\u05d5\u05d1\u05e0\u05d9\u05ea \u05d5\u05de\u05ea\u05e7\u05d3\u05de\u05ea \u05d4\u05e4\u05dc\u05d8\u05e4\u05d5\u05e8\u05de\u05d4 \u05db\u05d5\u05dc\u05dc\u05ea \u05d0\u05d1\u05d8\u05d7\u05ea Zero Trust \u05d5-API Security \u05dc\u05d4\u05d1\u05d8\u05d7\u05ea \u05d4\u05d2\u05e0\u05d4 \u05d1\u05db\u05dc \u05e9\u05dc\u05d1 \u05d1\u05ea\u05d4\u05dc\u05d9\u05da \u05d4\u05e4\u05d9\u05ea\u05d5\u05d7. \u05d0\u05e8\u05db\u05d9\u05d8\u05e7\u05d8\u05d5\u05e8\u05ea Microservices \u05d5\u05d0\u05d5\u05d8\u05d5\u05de\u05e6\u05d9\u05d4 \u05e9\u05d9\u05de\u05d5\u05e9 \u05d1-Microservices \u05de\u05d0\u05e4\u05e9\u05e8 \u05e9\u05d3\u05e8\u05d5\u05d2\u05d9\u05dd \u05d3\u05d9\u05e0\u05de\u05d9\u05d9\u05dd, \u05d0\u05d5\u05d8\u05d5\u05de\u05e6\u05d9\u05d4 \u05d5\u05ea\u05d6\u05de\u05d5\u05e8 \u05d1\u05d9\u05df \u05d3\u05d5\u05de\u05d9\u05d9\u05e0\u05d9\u05dd \u05dc\u05e9\u05d9\u05e4\u05d5\u05e8 \u05d1\u05d9\u05e6\u05d5\u05e2\u05d9\u05dd. Observability \u05d5\u05de\u05e9\u05d5\u05d1 \u05dc\u05e9\u05d9\u05e4\u05d5\u05e8 Observability \u05d5-Feedback Loop \u05de\u05d0\u05e4\u05e9\u05e8\u05d9\u05dd \u05e0\u05d9\u05d8\u05d5\u05e8 \u05de\u05ea\u05de\u05d9\u05d3 \u05d5\u05e9\u05d9\u05e4\u05d5\u05e8 \u05de\u05ea\u05de\u05e9\u05da \u05e9\u05dc \u05d4\u05e4\u05dc\u05d8\u05e4\u05d5\u05e8\u05de\u05d4.", "text_preview": "[SLIDE 1]: \u05d4\u05d9\u05ea\u05e8\u05d5\u05e0\u05d5\u05ea \u05d5\u05d4\u05d9\u05d9\u05e9\u05d5\u05de\u05d9\u05dd \u05e9\u05dc \u05e4\u05dc\u05d8\u05e4\u05d5\u05e8\u05de\u05ea OC2ELOT \u05d1\u05e9\u05d9\u05dc\u05d5\u05d1 \u05e4\u05ea\u05e8\u05d5\u05df VAST-Leidos-NVIDIA \u05d7\u05d3\u05e9\u05e0\u05d5\u05ea \u05d8\u05db\u05e0\u05d5\u05dc\u05d5\u05d2\u05d9\u05ea \u05dc\u05e9\u05d9\u05e4\u05d5\u05e8 \u05d1\u05d9\u05e6\u05d5\u05e2\u05d9\u05dd \u05d5\u05d9\u05e2\u05d9\u05dc\u05d5\u05ea \u05de\u05e2\u05e8\u05db\u05ea\u05d9\u05ea [SLIDE 2]: \u05d4\u05d9\u05d9\u05d7\u05d5\u05d3\u05d9\u05d5\u05ea \u05e9\u05dc \u05d4\u05e4\u05ea\u05e8\u05d5\u05df \u05d4\u05de\u05e9\u05d5\u05dc\u05d1 [SLIDE 3]: \u05de\u05d4\u05d9 \u05d4\u05d9\u05d9\u05d7\u05d5\u05d3\u05d9\u05d5\u05ea \u05e9\u05dc \u05d4\u05e4\u05ea\u05e8\u05d5\u05df VAST-Leidos-NVIDIA \u05ea\u05e9\u05ea\u05d9\u05ea \u05d0\u05d7\u05e1\u05d5\u05df \u05e4\u05d8\u05d4-\u05d1\u05d9\u05d9\u05d8\u05d9\u05ea VAST \u05de\u05e6\u05d9\u05e2\u05d4 \u05d0\u05d7\u05e1\u05d5\u05df \u05d1\u05e7\u05e0\u05d4 \u05de\u05d9\u05d3\u05d4 \u05e4\u05d8\u05d4-\u05d1\u05d9\u05d9\u05d8\u05d9 \u05e2\u05dd \u05d7\u05d9\u05e4