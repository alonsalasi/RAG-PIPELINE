    {
      "mode": "managed",
      "type": "aws_iam_policy",
      "name": "lambda_api_policy",
      "provider": "provider[\"registry.terraform.io/hashicorp/aws\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "arn": "arn:aws:iam::528005785618:policy/pdfquery-lambda-api-policy",
            "attachment_count": 1,
            "description": "Permissions for Lambda API to download FAISS index from S3, call Bedrock, generate presigned URLs, and log to CloudWatch.",
            "id": "arn:aws:iam::528005785618:policy/pdfquery-lambda-api-policy",
            "name": "pdfquery-lambda-api-policy",
            "name_prefix": "",
